
// =============== embedded ksm

logging {
    level  = "debug"
    format = "logfmt"
}

livedebugging {
  enabled = true
}

prometheus.exporter.self "default" {
}

prometheus.scrape "alloymetrics" {
  targets    = prometheus.exporter.self.default.targets
  forward_to = [prometheus.remote_write.default.receiver]
}

//kubestate ************** the name of the component is kubestate
prometheus.exporter.kubestate "kubestate" {
    poll_frequency = "10"
    poll_timeout = "20"
    port = 37425
}

prometheus.scrape "kube_state_metrics" {
  clustering {
        enabled = true
  }
  //the below target also works
  targets = [
    {
      __address__ = "localhost:37425",
    },
  ]
  forward_to = [prometheus.remote_write.default.receiver]
}

prometheus.remote_write "default" {
  external_labels = {
        "kube_cluster_name" = "test_ksm_metrics",
        "host_hostname" = sys.env("HOSTNAME"),

    }
  endpoint {
    url = "http://mimir-distributor.mimir.svc.cluster.local:8080/api/v1/push"
          headers = {
		        "X-Scope-OrgID" = "anonymous",
		      }
    }
}