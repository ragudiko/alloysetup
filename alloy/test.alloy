//kubestate
prometheus.exporter.kubestate "kubestate" {
    poll_frequency = "10"
    poll_timeout = "20"
    
	  // resources = 
	  // clustering =
    // http_listen_port =

    // metric_allowlist = ["kube_cronjob_info","kube_cronjob_labels","kube_daemonset_labels",]
    // resources = ["cronjobs", "daemonsets"]
    
}

prometheus.scrape "kubestate" {
    targets    = prometheus.exporter.kubestate.kubestate.targets
    // targets = [
    // {
    //   __address__ = "localhost:37425",
    // },
  // ]
    job_name   = "kubestate-metrics"
    forward_to = [ prometheus.remote_write.default.receiver ]    
}

prometheus.remote_write "default" {
  external_labels = {
        "kube_cluster_name" = "test_ksm_metrics",

    }
  endpoint {
    url = "http://mimir-distributor.mimir.svc.cluster.local:8080/api/v1/push"
          headers = {
		        "X-Scope-OrgID" = "anonymous",
		      }
    }
}